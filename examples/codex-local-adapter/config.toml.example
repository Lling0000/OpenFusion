# Recommended Codex-facing default. If Codex shows this in the model selector,
# Codex is entering through the OpenFusion Auto strategy.
model = "openfusion/auto"
model_provider = "openfusion"

[model_providers.openfusion]
name = "OpenFusion local"
base_url = "http://127.0.0.1:8787/v1"
env_key = "OPENFUSION_API_KEY"
