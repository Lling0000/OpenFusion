{
  "upstream": {
    "baseURL": "https://your-relay.example.com/v1",
    "apiKeyEnv": "YOUR_RELAY_API_KEY",
    "appName": "OpenFusion",
    "siteURL": "https://github.com/Lling0000/OpenFusion"
  },
  "roles": {
    "fast": {
      "model": "your-fast-model",
      "description": "Fast and cheap first pass.",
      "pricing": {
        "inputUsdPer1M": 0.1,
        "outputUsdPer1M": 0.4
      }
    },
    "reasoner": {
      "model": "your-reasoning-model",
      "description": "Planning, tradeoffs, and difficult reasoning.",
      "pricing": {
        "inputUsdPer1M": 3,
        "outputUsdPer1M": 15
      }
    },
    "coder": {
      "model": "your-code-model",
      "description": "Code, debugging, tests, and implementation.",
      "pricing": {
        "inputUsdPer1M": 0.5,
        "outputUsdPer1M": 1.5
      }
    },
    "verifier": {
      "model": "your-review-model",
      "description": "Verification, risk checks, and critique.",
      "pricing": {
        "inputUsdPer1M": 2,
        "outputUsdPer1M": 8
      }
    },
    "writer": {
      "model": "your-polish-model",
      "description": "Final synthesis and concise writing.",
      "pricing": {
        "inputUsdPer1M": 1,
        "outputUsdPer1M": 4
      }
    }
  },
  "routing": {
    "rules": [
      {
        "role": "verifier",
        "keywords": ["incident", "postmortem"],
        "score": 3,
        "reason": "incident-review signal"
      }
    ]
  },
  "fusion": {
    "minPanel": 2,
    "maxPanel": 4,
    "judgeRole": "verifier",
    "synthesizerRole": "writer",
    "toolRole": "writer",
    "maxUpstreamCalls": 6,
    "costEstimate": {
      "inputTokensPerCall": 2000,
      "outputTokensPerCall": 1000,
      "maxUsd": 0.1
    },
    "timeoutMs": 90000
  }
}
